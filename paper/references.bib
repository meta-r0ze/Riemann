@misc{esteban_nufit-60_2024,
	title = {{NuFit}-6.0: {Updated} global analysis of three-flavor neutrino oscillations},
	copyright = {Creative Commons Attribution 4.0 International},
	shorttitle = {{NuFit}-6.0},
	url = {https://arxiv.org/abs/2410.05380},
	doi = {10.48550/ARXIV.2410.05380},
	abstract = {We present an updated global analysis of neutrino oscillation data as of September 2024. The parameters \$θ\_\{12\}\$, \$θ\_\{13\}\$, \$Δm{\textasciicircum}2\_\{21\}\$, and \${\textbar}Δm{\textasciicircum}2\_\{3{\textbackslash}ell\}{\textbar}\$ (\${\textbackslash}ell = 1,2\$) are well-determined with relative precision at \$3σ\$ of about 13{\textbackslash}\%, 8{\textbackslash}\%, 15{\textbackslash}\%, and 6{\textbackslash}\%, respectively. The third mixing angle \$θ\_\{23\}\$ still suffers from the octant ambiguity, with no clear indication of whether it is larger or smaller than \$45{\textasciicircum}{\textbackslash}circ\$. The determination of the leptonic CP phase \$δ\_\{CP\}\$ depends on the neutrino mass ordering: for normal ordering the global fit is consistent with CP conservation within \$1σ\$, whereas for inverted ordering CP-violating values of \$δ\_\{CP\}\$ around \$270{\textasciicircum}{\textbackslash}circ\$ are favored against CP conservation at more than \$3.6σ\$. While the present data has in principle \$2.5\$--\$3σ\$ sensitivity to the neutrino mass ordering, there are different tendencies in the global data that reduce the discrimination power: T2K and NOvA appearance data individually favor normal ordering, but they are more consistent with each other for inverted ordering. Conversely, the joint determination of \${\textbar}Δm{\textasciicircum}2\_\{3{\textbackslash}ell\}{\textbar}\$ from global disappearance data prefers normal ordering. Altogether, the global fit including long-baseline, reactor and IceCube atmospheric data results into an almost equally good fit for both orderings. Only when the \$χ{\textasciicircum}2\$ table for atmospheric neutrino data from Super-Kamiokande is added to our \$χ{\textasciicircum}2\$, the global fit prefers normal ordering with \$Δχ{\textasciicircum}2 = 6.1\$. We provide also updated ranges and correlations for the effective parameters sensitive to the absolute neutrino mass from \$β\$-decay, neutrinoless double-beta decay, and cosmology.},
	urldate = {2026-01-23},
	publisher = {arXiv},
	author = {Esteban, Ivan and Gonzalez-Garcia, M. C. and Maltoni, Michele and Martinez-Soler, Ivan and Pinheiro, João Paulo and Schwetz, Thomas},
	year = {2024},
	note = {Version Number: 2},
	keywords = {FOS: Physical sciences, High Energy Physics - Experiment (hep-ex), High Energy Physics - Phenomenology (hep-ph)},
}

